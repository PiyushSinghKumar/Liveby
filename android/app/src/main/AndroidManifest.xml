<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">
        </activity>

        <!-- Score-based icon aliases (only one enabled at a time) -->
        <activity-alias android:name=".MainActivityScoreNone"
            android:targetActivity=".MainActivity"
            android:icon="@mipmap/ic_launcher_score_none"
            android:roundIcon="@mipmap/ic_launcher_score_none_round"
            android:enabled="true" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>
        <activity-alias android:name=".MainActivityScoreBad"
            android:targetActivity=".MainActivity"
            android:icon="@mipmap/ic_launcher_score_bad"
            android:roundIcon="@mipmap/ic_launcher_score_bad_round"
            android:enabled="false" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>
        <activity-alias android:name=".MainActivityScorePoor"
            android:targetActivity=".MainActivity"
            android:icon="@mipmap/ic_launcher_score_poor"
            android:roundIcon="@mipmap/ic_launcher_score_poor_round"
            android:enabled="false" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>
        <activity-alias android:name=".MainActivityScoreOk"
            android:targetActivity=".MainActivity"
            android:icon="@mipmap/ic_launcher_score_ok"
            android:roundIcon="@mipmap/ic_launcher_score_ok_round"
            android:enabled="false" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>
        <activity-alias android:name=".MainActivityScoreGood"
            android:targetActivity=".MainActivity"
            android:icon="@mipmap/ic_launcher_score_good"
            android:roundIcon="@mipmap/ic_launcher_score_good_round"
            android:enabled="false" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>
        <activity-alias android:name=".MainActivityScorePerfect"
            android:targetActivity=".MainActivity"
            android:icon="@mipmap/ic_launcher_score_perfect"
            android:roundIcon="@mipmap/ic_launcher_score_perfect_round"
            android:enabled="false" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
</manifest>
