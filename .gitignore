# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Signing keys - never commit these
*.keystore
*.jks

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Android build artifacts
android/app/build/
android/build/
android/.gradle/
android/local.properties
*.apk
*.aab

# iOS build artifacts
ios/App/build/
ios/App/Pods/
ios/App/App.xcworkspace/xcuserdata/
ios/build/
ios/ipa/
*.ipa

# Personal data (stays local, not committed)
data/
standards.txt

# OS
Thumbs.db
